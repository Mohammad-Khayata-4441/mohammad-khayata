{
  "name": "@repo/cms-types",
  "version": "0.0.0",
  "private": true,
  "description": "OpenAPI-generated types from the CMS",
  "types": "./index.d.ts",
  "scripts": {
    "generate:openapi-types": "openapi-typescript openapi.json -o generated/openapi.d.ts"
  },
  "exports": {
    ".": { "types": "./index.d.ts" },
    "./generated/openapi": { "types": "./generated/openapi.d.ts" },
    "./openapi.json": "./openapi.json"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0"
  }
}
